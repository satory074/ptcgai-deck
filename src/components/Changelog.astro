---
import type { Snapshot } from "@/lib/deck";

interface Props {
  snapshots: Snapshot[];
}
const { snapshots } = Astro.props;
---

<details open class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] overflow-hidden">
  <summary class="flex cursor-pointer items-center justify-between gap-3 px-5 py-3.5 select-none list-none border-l-2 border-l-[var(--color-accent)] bg-[var(--color-surface)]">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text)]">更新履歴</h2>
    <span class="text-xs text-[var(--color-text-subtle)] transition-transform group-open:rotate-180" aria-hidden="true">▼</span>
  </summary>

  <ol class="px-5 sm:px-6 py-2">
    {
      snapshots.map((snap, i) => (
        <li class:list={["py-4", i > 0 && "border-t border-[var(--color-border)]"]}>
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <time class="tnum text-xs text-[var(--color-text-subtle)]">{snap.date}</time>
            <span class="rounded border border-[var(--color-border-strong)] px-1.5 py-0.5 text-[11px] font-medium text-[var(--color-text-muted)]">
              {snap.id}
            </span>
            <h3 class="font-medium text-[var(--color-text)]">{snap.label}</h3>
          </div>

          <ul class="mt-2.5 space-y-2">
            {snap.changes.map((ch) => (
              <li class="flex gap-2.5 text-sm">
                {ch.date && ch.date !== snap.date && (
                  <time class="tnum mt-0.5 shrink-0 text-[11px] text-[var(--color-text-subtle)]">{ch.date}</time>
                )}
                {ch.type === "in" && (
                  <span class="tnum mt-0.5 shrink-0 rounded px-1.5 text-xs font-semibold text-[var(--color-in)] bg-[var(--color-in-bg)]">
                    +{ch.count}
                  </span>
                )}
                {ch.type === "out" && (
                  <span class="tnum mt-0.5 shrink-0 rounded px-1.5 text-xs font-semibold text-[var(--color-out)] bg-[var(--color-out-bg)]">
                    −{ch.count}
                  </span>
                )}
                {ch.type === "note" && (
                  <span class="mt-0.5 shrink-0 text-[var(--color-text-subtle)]" aria-hidden="true">
                    ·
                  </span>
                )}
                <span class="min-w-0 text-[var(--color-text-muted)]">
                  {ch.name && <span class="font-medium text-[var(--color-text)]">{ch.name}</span>}
                  {ch.name && " — "}
                  {ch.reason}
                </span>
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>
</details>
