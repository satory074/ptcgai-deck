---
interface Props {
  rationale: string;
  energyIdentity: string;
}
const { rationale, energyIdentity } = Astro.props;
---

<section class="rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] px-5 sm:px-6 py-5">
  <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-accent-bright)]">なぜこの構築か</h2>
  <p class="mt-3 text-sm text-[var(--color-text-muted)]" style="line-height: var(--leading-jp-body);">
    {rationale}
  </p>
  <dl class="mt-4 flex flex-wrap gap-x-6 gap-y-2 border-t border-[var(--color-border)] pt-4 text-sm">
    <div class="flex items-center gap-2">
      <dt class="text-[var(--color-text-subtle)]">エネルギー</dt>
      <dd class="font-medium text-[var(--color-text)]">{energyIdentity}</dd>
    </div>
  </dl>
</section>
