---
import type { Card } from "@/lib/deck";
import { typeMeta, mainDamage, subtypeLabel } from "@/lib/deck";

interface Props {
  card: Card;
}
const { card } = Astro.props;
const m = typeMeta(card.type);
const accent = m?.color ?? "#8a7f6e"; // トレーナーは中立色
const dmg = card.category === "Pokémon" ? mainDamage(card) : null;
const hasImage = !!card.image;
---

{
  /* 実カード画像（公開CDNからホットリンク）。クリックで拡大（Lightbox）。
     読み込み失敗時は onerror でボタンを隠し、下のタイポタイルに切替。 */
  hasImage && (
    <button
      type="button"
      class="card-zoom group block w-full cursor-zoom-in rounded-lg transition hover:ring-2 hover:ring-[var(--color-accent)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)]"
      data-large={card.imageLarge ?? card.image}
      data-name={card.name}
      aria-label={`${card.name} を拡大表示`}
    >
      <img
        src={card.image}
        alt={card.name}
        loading="lazy"
        decoding="async"
        width="245"
        height="342"
        class="block w-full h-auto rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] transition group-hover:brightness-105"
        onerror="this.closest('.card-zoom').style.display='none'; this.closest('.card-zoom').nextElementSibling.style.display='flex';"
      />
    </button>
  )
}

<div
  class:list={[
    "h-full flex-col rounded-lg border bg-[var(--color-card)] overflow-hidden",
    hasImage ? "hidden" : "flex",
  ]}
  style={card.category === "Energy" ? undefined : `border-color:${accent}66;`}
>
  {
    card.category === "Energy" ? (
      <div
        class="flex-1 grid place-items-center min-h-[64px]"
        style={`background:${accent}; color:${m?.text ?? "#fff"};`}
        title={card.name}
      >
        <span class="text-lg font-bold leading-none">{m?.jp ?? "?"}</span>
      </div>
    ) : (
      <>
        <div class="flex items-center justify-between gap-1 px-2 py-1" style={`background:${accent}1f;`}>
          {card.category === "Pokémon" ? (
            <span
              class="grid place-items-center w-4 h-4 rounded-full text-[10px] font-bold leading-none"
              style={`background:${accent}; color:${m?.text ?? "#fff"};`}
              aria-hidden="true"
            >
              {m?.jp}
            </span>
          ) : (
            <span class="text-[10px] font-medium uppercase tracking-wide text-[var(--color-text-subtle)]">
              {subtypeLabel(card.subtype)}
            </span>
          )}
          {card.hp != null && (
            <span class="tnum text-[10px] font-semibold text-[var(--color-text-muted)]">HP {card.hp}</span>
          )}
        </div>
        <div class="flex flex-1 flex-col px-2 py-1.5">
          <span class="text-[10px] font-medium leading-tight line-clamp-2 break-words text-[var(--color-text)]">
            {card.name}
          </span>
          {dmg != null && (
            <span class="tnum mt-auto pt-1 text-right text-sm font-bold text-[var(--color-accent-bright)]">{dmg}</span>
          )}
        </div>
      </>
    )
  }
</div>
