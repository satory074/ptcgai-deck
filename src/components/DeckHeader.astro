---
import TypeBadge from "./TypeBadge.astro";

interface Ladder { submissionRef: string; mu: number; asOf: string; status: string; note?: string }
interface Props {
  archetype: string;
  versionLabel: string;
  date: string;
  energyIdentity: string;
  ladder?: Ladder;        // per-version μ
  fallbackLadder: Ladder; // top-level, used when a snapshot has no own ladder
}
const { archetype, versionLabel, date, energyIdentity, ladder, fallbackLadder } = Astro.props;
const lad = ladder ?? fallbackLadder;
const statusJp =
  lad.status === "live" ? "稼働中"
  : lad.status === "converging" ? "収束中"
  : lad.status === "validating" ? "検証中"
  : lad.status === "archived" ? "過去版"
  : lad.status;
const isArchived = lad.status === "archived";
---

<header class="relative overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] px-6 sm:px-8 py-8 sm:py-10">
  <div
    class="pointer-events-none absolute -top-24 -right-16 h-64 w-64 rounded-full blur-3xl"
    style="background: var(--color-accent-glow);"
    aria-hidden="true"
  >
  </div>

  <div class="relative">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-text-subtle)]">
      Kaggle · pokemon-tcg-ai-battle
    </p>
    <h1 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight">
      ptcgai <span class="text-[var(--color-accent-bright)]">現行デッキ</span>
    </h1>

    <p class="mt-3 flex flex-wrap items-center gap-2 text-base text-[var(--color-text-muted)]">
      <TypeBadge type="{F}" showLabel />
      <span>{archetype}</span>
    </p>

    <div class="mt-5 flex flex-wrap items-center gap-2 text-xs">
      <span class="rounded-full border border-[var(--color-border-strong)] bg-[var(--color-card)] px-3 py-1 font-medium text-[var(--color-text)]">
        {versionLabel}<span class="tnum ml-2 font-normal text-[var(--color-text-subtle)]">{date}</span>
      </span>
      <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-[var(--color-text-muted)]">
        60枚
      </span>
      <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-[var(--color-text-muted)]">
        {energyIdentity}
      </span>
    </div>

    <div class="mt-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] px-4 py-3 text-sm">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
        <span class="inline-flex items-center gap-2 font-medium text-[var(--color-text)]">
          <span
            class="h-2 w-2 rounded-full"
            style={`background: var(${isArchived ? "--color-text-subtle" : "--color-in"})`}
            aria-hidden="true"></span>
          ラダー{statusJp}
        </span>
        <span class="text-[var(--color-text-muted)]">μ <span class="tnum text-[var(--color-text)]">{lad.mu}</span></span>
        <span class="text-[var(--color-text-muted)]">submission <span class="tnum text-[var(--color-text)]">{lad.submissionRef}</span></span>
        <span class="text-[var(--color-text-subtle)]">（{lad.asOf} 時点）</span>
      </div>
      {lad.note && (
        <p class="mt-2 text-xs text-[var(--color-text-subtle)]" style="line-height: var(--leading-jp-body);">{lad.note}</p>
      )}
    </div>
  </div>
</header>
